set number relativenumber
set nocompatible

filetype on
filetype plugin on
filetype indent on

syntax on

set shiftwidth=2
set tabstop=2
set expandtab

set nobackup

set scrolloff=10
set mouse=a

set nowrap
set incsearch
set smartcase

set showcmd
set showmode
set showmatch
set hlsearch

set history=1000
