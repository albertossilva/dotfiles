#!/usr/bin/env bash

DIR="~/.config/wallpapers"

selected=$(
    for img in ~/.config/wallpapers/*.{png,jpg,jpeg}; do
        [ -e "$img" ] || continue
        printf "%s\0icon\x1f%s\n" "$(basename "$img")" "$img"
    done | rofi -dmenu -show-icons
)

[ -n "$selected" ] || exit 0

config="$HOME/.dotfiles/config/hypr/hyprpaper.conf"
selected="$HOME/.config/wallpapers/$selected"

sed -i "s|^\([[:space:]]*path[[:space:]]*=[[:space:]]*\).*|\1$selected|" "$config"
killall hyprpaper
hyprctl eval 'hl.exec_cmd("hyprpaper")'
